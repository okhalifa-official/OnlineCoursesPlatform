DB=your_mongodb_connection
JWT_SECRET=your_jwt_secret

KASHIER_API_KEY=your_kashier_api_key
KASHIER_SECRET_KEY=your_kashier_secret_key
KASHIER_MERCHANT_ID=your_merchant_id
KASHIER_MERCHANT_REDIRECT_URL=https://your-frontend-domain.com/payment
KASHIER_SERVER_WEBHOOK_URL=https://your-backend-domain.com/api/payment-gateway/kashier/webhook

KASHIER_MODE=test
KASHIER_ALLOWED_METHODS=card
KASHIER_DISPLAY_LANGUAGE=en


